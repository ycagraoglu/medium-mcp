{
  "name": "medium-mcp",
  "version": "1.0.0",
  "private": true,
  "description": "Read-only Medium MCP server using a persistent Playwright browser session.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "login": "tsx src/login.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "playwright": "^1.54.1",
    "turndown": "^7.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@types/turndown": "^5.0.5",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
